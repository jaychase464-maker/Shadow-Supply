# Normalize text files
* text=auto

*.cs text eol=lf
*.shader text eol=lf
*.shadergraph text eol=lf
*.hlsl text eol=lf
*.cginc text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.uxml text eol=lf
*.uss text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.mat text eol=lf
*.controller text eol=lf
*.anim text eol=lf

# Git LFS — 3D and source art
*.fbx filter=lfs diff=lfs merge=lfs -text
